{
    "build_debug": {
        "description": "Build debug task_tracker",
        "working_dir": "./build/Debug",
        "scripts": [
            "cmake ../.. -B . -DBUILD_TASK_TRACKER=ON -DCMAKE_BUILD_TYPE=Debug",
            "cmake --build . --target TASK_TRACKER --parallel $(($(nproc)-1))"
        ]
    },
    "build_release": {
        "description": "Build release task_tracker",
        "working_dir": "./build/Release",
        "scripts": [
            "cmake ../.. -B . -DBUILD_TASK_TRACKER=ON -DCMAKE_BUILD_TYPE=Release",
            "cmake --build . --target TASK_TRACKER --parallel $(($(nproc)-1))"
        ]
    },
    "run_debug": {
        "description": "Run ./build/Debug/task_tracker/TASK_TRACKER",
        "scripts": [
            "./build/Debug/task_tracker/TASK_TRACKER"
        ]
    },
    "run_release": {
        "description": "Run ./build/Release/task_tracker/TASK_TRACKER",
        "scripts": [
            "./build/Release/task_tracker/TASK_TRACKER"
        ]
    },
    "build_debug_and_run": {
        "description": "Build task_tracker and run ./build/Debug/task_tracker/TASK_TRACKER",
        "scripts": [
            "@@ task_tracker build_debug",
            "@@ task_tracker run_debug"
        ]
    },
    "build_release_and_run": {
        "description": "Build task_tracker and run ./build/Release/TASK_TRACKER",
        "scripts": [
            "@@ task_tracker build_release",
            "@@ task_tracker run_release"
        ]
    }
}
