{
    "build_release": {
        "description": "Build deps to build/Release",
        "working_dir": "./build/Release",
        "scripts": [
            "../../venv/bin/conan install ../.. --profile:host=../../Release-conanprofile --profile:build=../../Release-conanprofile --build missing -s build_type=Release"
        ]
    },
    "build_debug": {
        "description": "Build deps to build/Debug",
        "working_dir": "./build/Debug",
        "scripts": [
            "../../venv/bin/conan install ../.. --profile:host=../../Debug-conanprofile --profile:build=../../Debug-conanprofile --build missing -s build_type=Debug"
        ]
    },
    "build_minizip": {
        "description": "Build minizip",
        "working_dir": "./recipes/minizip/all",
        "scripts": [
            "../../../venv/bin/conan create . --profile=../../../Release-conanprofile --build=missing"
        ]
    },
    "build": {
        "description": "Build Conan source files",
        "scripts": [
            "mkdir -p build/Debug build/Release",
            "./venv/bin/conan profile detect || true",
            "@@ conan build_minizip",
            "@@ conan build_release",
            "@@ conan build_debug"
        ]
    }
}
