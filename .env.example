# general
CONTAINER_RESTART=unless-stopped
CONTAINER_CPUS_LIMIT=1.0
CONTAINER_MEMORY_LIMIT=512M
# RUNNER_IMAGE=ubuntu:latest
# BUILDER_IMAGE=ubuntu:latest
# PYTHON_RUNNER_IMAGE=python:latest
RUNNER_IMAGE=alpine:latest
BUILDER_IMAGE=alpine:latest
PYTHON_RUNNER_IMAGE=python:alpine
USE_OAUTH=false
# USE_OAUTH=true
AUTH_KEY=qwerty
COMPOSE_PROJECT_NAME=cpp-keber
COMPOSE_BAKE=true
COMPOSE_FILE=docker/bot.yml:docker/postgres.yml:docker/networks.yml:docker/task-tracker.yml:docker/youtube-api.yml
PROJECT_BUILD=debug
# PROJECT_BUILD=release

# postgres
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=qwerty
POSTGRES_DB=bot
POSTGRES_EXTERNAL_PORT=127.0.0.1:5432

# bot
BOT_USER=bot
BOT_ADMINS=[]
BOT_TOKEN=
BOT_WEBHOOK_URL=
BOT_EXTERNAL_PORT=127.0.0.1:8080
BOT_PASSWORD=qwerty
TELEGRAM_API_URL=https://api.telegram.org

# youtube_api
YOUTUBE_API_EXTERNAL_PORT=127.0.0.1:8081
YOUTUBE_API_TEST_YOUTUBE_VIDEO=https://www.youtube.com/watch?v=jiT2Mak9AzI

# downloader
DOWNLOADER_USER=downloader
DOWNLOADER_PASSWORD=qwerty
DOWNLOADER_QUEUE_NAME=downloader

# reader
READER_USER=reader
READER_PASSWORD=qwerty

# task_tracker
TASK_TRACKER_USER=task_tracker
TASK_TRACKER_PASSWORD=qwerty
TASK_TRACKER_EXTERNAL_PORT=8082